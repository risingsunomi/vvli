# Copy this file to .env and edit values for local defaults.
# Command-line flags override values from .env.

VVLI_REPO=unsloth/Qwen2.5-0.5B-Instruct
VVLI_REVISION=main
VVLI_CACHE=.vvli-cache
VVLI_FORMAT=auto

# Optional model files. Useful for GGUF and VLM repos.
# VVLI_WEIGHTS=Llama-3.2-1B-Instruct-BF16.gguf
# VVLI_MMPROJ=mmproj-F16.gguf

# Optional prompt/image defaults.
# VVLI_PROMPT=Explain CPU inference in one paragraph.
# VVLI_IMAGE=./image.jpg

VVLI_MAX_NEW_TOKENS=64
VVLI_CTX=512
VVLI_THREADS=0

VVLI_DOWNLOAD=true
VVLI_CHAT_TEMPLATE=true
VVLI_STREAM=true

VVLI_TEMPERATURE=0.8
VVLI_TOP_P=0.95
VVLI_TOP_K=40
VVLI_REPEAT_PENALTY=1.10
VVLI_REPEAT_LAST_N=64

# Optional reproducibility / deterministic decoding.
# VVLI_SEED=1234
# VVLI_GREEDY=false
